{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .)",
      "Bash(> /dev/sd*)",
      "Bash(dd if=*of=/dev/sd*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)"
    ],
    "allow": [
      "Read:*",
      "Glob:*",
      "Grep:*",
      "Edit:*",
      "Write:*",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(jq:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(uv run:*)",
      "Bash(uv run ruff check:*)",
      "Bash(nvidia-smi:*)",
      "mcp__serena",
      "mcp__sequential-thinking",
      "mcp__context7",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(tailscale:*)",
      "Bash(ping:*)",
      "Bash(ip:*)",
      "Bash(ss:*)",
      "Bash(iptables:*)",
      "Bash(systemctl:*)",
      "Bash(sudo systemctl:*)",
      "Bash(journalctl:*)",
      "Bash(dmesg:*)",
      "Bash(ps:*)",
      "Bash(updatedb:*)",
      "Bash(python3:*)",
      "Bash(uvx:*)",
      "Bash(node:*)",
      "Bash(claude:*)",
      "Bash(mkdir:*)",
      "Bash(tee:*)",
      "Bash(sed:*)",
      "Bash(test:*)",
      "Bash(bash:*)",
      "Bash(source:*)",
      "Bash(~/.local/bin/gh-issue-fetch.sh:*)",
      "Bash(~/.local/bin/gh-progress-sync.sh:*)",
      "Bash(~/.local/bin/gh-retrospective.sh:*)",
      "Bash(gh_projects_set_done:*)",
      "Bash(gh_projects_set_in_progress:*)",
      "Bash(gtr-finish:*)",
      "Bash(project-locate:*)",
      "Bash(curl:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv pip:*)",
      "Bash(uv --version:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(paste:*)",
      "Bash(timeout:*)",
      "Bash(time:*)",
      "Bash(xxd:*)",
      "Bash(npx:*)",
      "Bash(xargs:*)",
      "Bash(for:*)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.lambda.ai)",
      "WebFetch(domain:cloud.lambdalabs.com)",
      "WebFetch(domain:lambdalabs.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:docs.coderabbit.ai)",
      "SlashCommand(/gh:usage)"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/suggest-claude-md-hook.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/suggest-claude-md-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  }
}

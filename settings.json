{
  "permissions": {
    "allow": [
      "Read:*",
      "Glob:*",
      "Grep:*",
      "Edit:*",
      "Write:*",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(jq:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(uv run :* --help::*)",
      "Bash(uv run ruff check:*)",
      "Bash(nvidia-smi:*)",
      "Bash(bash :* --help::*)",
      "mcp__serena",
      "mcp__sequential-thinking",
      "mcp__context7",
      "WebSearch",
      "WebFetch(domain:github.com)"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/suggest-claude-md-hook.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/suggest-claude-md-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js"
  },
  "outputStyle": "ojosama"
}
